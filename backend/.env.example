NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://user:password@host/fastpos?sslmode=require

# JWT
JWT_SECRET=<64-byte-hex>
JWT_REFRESH_SECRET=<baska-64-byte-hex>
JWT_EXPIRES_IN=24h
JWT_EMPLOYEE_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:19006

# Claude AI (owner chatbot üçün)
ANTHROPIC_API_KEY=sk-ant-...

# Rate limit
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
